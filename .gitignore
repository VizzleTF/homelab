# Terraform sensitive files
.terraform*
terraform_*/.terraform*
terraform_*/_out/
terraform_*/*.tfplan
*.tfstate
*.tfstate.*

# Secret files (allow examples + chart templates)
*secret*.yaml
*Secret*.yaml
*_secret.yaml
*_Secret.yaml
!*example*.yaml
!*_example.yaml
!charts/**/templates/secret.yaml

# Backup files
*.bak
*.backup

# OS files
.DS_Store
Thumbs.db
.cursor
.trae

# Workspace-only artefacts (not part of the homelab repo)
/.claudeignore
/.editorconfig
/.kiro/
/.qwen/
/.vscode/
/obsidian
/docs/

# CLAUDE.md and .claude/ are committed to Forgejo but stripped from the GitHub
# mirror by the `Strip workspace-only paths for GitHub mirror` step in
# .forgejo/workflows/ci.yaml.
# Inside .claude/: ignore everything by default, whitelist explicit subtrees.
# Per-machine local files (settings.local.json, *.lock) and ephemeral subdirs
# (plans/, knowledgebase/, output-styles/, ...) stay untracked automatically.
/.claude/*
!/.claude/skills/
!/.claude/reference/
!/.claude/agents/
!/.claude/hooks/
!/.claude/settings.json
# Devcontainer config — committed to Forgejo and mirrored to public GitHub.
!/.devcontainer/
# vault_secrets_backup.yaml is matched by *secret*.yaml above + .git-hooks/blocklist.sh
