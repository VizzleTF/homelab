# Terraform sensitive files
provider_vars.tf
terraform.exe
.terraform*
terraform/provider_vars.tf
terraform/terraform.exe
terraform/.terraform*
terraform/variables.tf

# Ansible sensitive files
ansible/roles/okd_sn_config_daemons/files/install-config.yaml

# Kubespray
kubespray*

# Kubernetes secrets and sensitive manifests
manifests/letsencrypt/CloudFlare_Secret.yaml
manifests/keycloak/secret.yaml
manifests/cluster-status/proxmox_secret.yaml
manifests/cluster-status/kubeconf_secret.yaml
manifests/crossplane/keycloak-provider-config.yaml
manifests/crowdsec/notification-telegram.yaml

# Helm values with passwords
helm/values/applications/nextcloud.values.yaml.gotmpl
helm/values/applications/couchdb.values.yaml.gotmpl
helm/values/security/keycloak.values.yaml

# Any other secret files (but not examples)
*secret*.yaml
*Secret*.yaml
*_secret.yaml
*_Secret.yaml
# Allow example files
!*example*.yaml
!*_example.yaml
# Allow Helm chart templates
!charts/**/templates/secret.yaml

# Backup files
*.bak
*.backup

# OS files
.DS_Store
Thumbs.db
.cursor

# Symlinks
.cursor
.trae

# Workspace-only artefacts (not part of the homelab repo)
/.claudeignore
/.editorconfig
/.kiro/
/.qwen/
/.vscode/
/obsidian
/docs/
/scripts/setup-proxmox-oidc.sh
# CLAUDE.md and .claude/ are committed to Forgejo but stripped from the GitHub mirror
# by the `Strip workspace-only paths for GitHub mirror` step in .forgejo/workflows/ci.yaml.
# Per-machine local files inside .claude/ stay untracked:
/.claude/settings.local.json
/.claude/*.lock
# vault_secrets_backup.yaml is matched by *secret*.yaml above + .git-hooks/blocklist.sh
