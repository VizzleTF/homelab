---
# Generated by terraform modules/ansible_inventory — do not edit by hand.
# Source: terraform_proxmox/configs/pve_hosts.yaml + var.pc_public_key
ansible_user: root
ansible_python_interpreter: /usr/bin/python3

admin_user: ${admin_user}
admin_groups:
%{ for g in admin_groups ~}
  - ${g}
%{ endfor ~}
admin_ssh_pubkey: "${admin_ssh_pubkey}"

trusted_cidrs:
%{ for cidr in trusted_cidrs ~}
  - ${cidr}
%{ endfor ~}

firewall_manager_host: ${firewall_manager_host}
