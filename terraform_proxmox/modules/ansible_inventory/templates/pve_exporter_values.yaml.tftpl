# Generated by terraform modules/ansible_inventory — do not edit by hand.
# Source: terraform_proxmox/configs/pve_hosts.yaml
# Helm chart: christianhuth/prometheus-pve-exporter
# Конвертация ServiceMonitor → VMServiceScrape делается VM Operator'ом
# (disable_prometheus_converter: false в values/infrastructure/victoria-metrics-k8s-stack.yaml).

chart: prometheus-pve-exporter

homelab-common:
  externalSecrets:
    - name: pve-exporter-auth
      vaultPath: victoria-metrics/pve-exporter
      data:
        - secretKey: pveUser
          property: user
        - secretKey: pveTokenName
          property: token_name
        - secretKey: pveTokenValue
          property: token_value
      templateData:
        pveUser: "{{ .pveUser }}"
        pveTokenName: "{{ .pveTokenName }}"
        pveTokenValue: "{{ .pveTokenValue }}"

env:
  pveAuthType: token
  pveExistingSecretName: pve-exporter-auth
  pveVerifySsl: false

resources:
  requests:
    cpu: 20m
    memory: 64Mi
  limits:
    cpu: 200m
    memory: 256Mi

serviceMonitor:
  enabled: true
  interval: 60s
  pveTargets:
%{ for host, ip in hosts ~}
    - ${ip}
%{ endfor ~}
