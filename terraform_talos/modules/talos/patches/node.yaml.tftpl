machine:
  install:
    disk: ${install_disk}
  features:
    stableHostname: false
  network:
    interfaces:
      - deviceSelector:
%{ if mac != "" ~}
          hardwareAddr: ${mac}
%{ else ~}
          physical: true
%{ endif ~}
        addresses:
          - ${address_cidr}
        routes:
          - network: 0.0.0.0/0
            gateway: ${gateway}
%{ if is_controlplane ~}
        vip:
          ip: ${vip}
%{ endif ~}
---
apiVersion: v1alpha1
kind: HostnameConfig
hostname: ${hostname}
auto: "off"
