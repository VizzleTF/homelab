{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":dependencyDashboard",
    ":pinDependencies",
    "helpers:pinGitHubActionDigests"
  ],
  "timezone": "UTC",
  "schedule": ["before 6am on monday"],
  "automergeSchedule": ["at any time"],
  "prConcurrentLimit": 10,
  "prHourlyLimit": 4,
  "labels": ["dependencies"],
  "commitMessagePrefix": "chore(deps):",
  "rebaseWhen": "auto",
  "packageRules": [
    {
      "matchUpdateTypes": ["major"],
      "addLabels": ["major"],
      "dependencyDashboardApproval": true
    },
    {
      "matchDatasources": ["docker"],
      "matchUpdateTypes": ["digest"],
      "enabled": false
    },
    {
      "matchUpdateTypes": ["patch", "pin"],
      "automerge": true,
      "addLabels": ["automerge"],
      "description": "Auto-merge patch and pin updates once PR is mergeable"
    },
    {
      "matchUpdateTypes": ["minor"],
      "automerge": true,
      "addLabels": ["automerge"],
      "description": "Auto-merge minor updates across the repo"
    },
    {
      "matchUpdateTypes": ["minor"],
      "matchDepNames": [
        "cilium",
        "vault",
        "cert-manager",
        "longhorn",
        "argo-cd",
        "victoria-metrics-k8s-stack"
      ],
      "automerge": false,
      "addLabels": ["critical-infra", "manual-review"],
      "description": "Critical infra — minor still requires manual review"
    },
    {
      "matchFileNames": ["terraform_proxmox/**"],
      "groupName": "terraform-providers",
      "description": "Group Terraform provider bumps"
    },
    {
      "matchFileNames": ["charts/**"],
      "groupName": "homelab-common",
      "description": "Group charts/ updates (rclone, etc.)"
    },
    {
      "matchFileNames": [".github/workflows/**"],
      "groupName": "github-actions",
      "description": "Group GitHub Actions workflow bumps"
    },
    {
      "matchFileNames": ["argocd/**"],
      "groupName": "argocd-charts",
      "description": "Group Helm targetRevision bumps in ArgoCD specs"
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/argocd/.+\\.ya?ml$/"
      ],
      "datasourceTemplate": "helm",
      "matchStrings": [
        "- name:\\s+[\\w-]+\\s+chart:\\s+(?<depName>[\\w-]+)\\s+repoURL:\\s+(?<registryUrl>https?://\\S+)[\\s\\S]*?targetRevision:\\s+[\"']?(?<currentValue>[\\w.-]+)[\"']?",
        "- name:\\s+(?<depName>[\\w-]+)\\s+repoURL:\\s+(?<registryUrl>https?://\\S+)[\\s\\S]*?targetRevision:\\s+[\"']?(?<currentValue>[\\w.-]+)[\"']?",
        "repoURL:\\s+(?<registryUrl>https?://\\S+)\\s+chart:\\s+(?<depName>[\\w-]+)\\s+targetRevision:\\s+[\"']?(?<currentValue>[\\w.-]+)[\"']?"
      ]
    }
  ]
}
