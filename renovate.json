{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":dependencyDashboard",
    ":pinDependencies",
    "helpers:pinGitHubActionDigests"
  ],
  "timezone": "UTC",
  "configMigration": true,
  "minimumReleaseAge": "3 days",
  "osvVulnerabilityAlerts": true,
  "vulnerabilityAlerts": {
    "enabled": true,
    "addLabels": ["security"],
    "minimumReleaseAge": null,
    "automerge": true
  },
  "prConcurrentLimit": 10,
  "prHourlyLimit": 4,
  "labels": ["dependencies"],
  "commitMessagePrefix": "chore(deps):",
  "rebaseWhen": "auto",
  "packageRules": [
    {
      "matchUpdateTypes": ["major"],
      "addLabels": ["major"],
      "dependencyDashboardApproval": true
    },
    {
      "matchDatasources": ["docker"],
      "matchUpdateTypes": ["digest"],
      "enabled": false
    },
    {
      "matchUpdateTypes": ["patch", "pin", "minor"],
      "automerge": true,
      "addLabels": ["automerge"]
    },
    {
      "matchUpdateTypes": ["minor"],
      "matchDepNames": [
        "cilium",
        "vault",
        "cert-manager",
        "longhorn",
        "argo-cd",
        "victoria-metrics-k8s-stack"
      ],
      "automerge": false,
      "addLabels": ["critical-infra", "manual-review"]
    },
    {
      "matchFileNames": ["terraform_proxmox/**"],
      "groupName": "terraform-providers"
    },
    {
      "matchFileNames": ["charts/**"],
      "groupName": "homelab-common"
    },
    {
      "matchFileNames": [".github/workflows/**", ".forgejo/workflows/**"],
      "groupName": "ci-actions"
    },
    {
      "matchManagers": ["github-actions"],
      "matchPackageNames": [
        "actions/upload-artifact",
        "actions/download-artifact"
      ],
      "allowedVersions": "<3.2.0",
      "description": "Forgejo runner supports only @actions/artifact v1.x (v1/v3 protocol). v3.2.x is a security backport that bumped @actions/artifact to v2 (v4 protocol) and fails with GHESNotSupportedError. v4.x is the same. Pin <3.2.0."
    },
    {
      "matchFileNames": ["argocd/applications/**", "argocd/infrastructure/**"],
      "groupName": "argocd-charts"
    },
    {
      "matchFileNames": ["argocd/values/applications/**", "argocd/apps/**"],
      "groupName": "applications"
    },
    {
      "matchFileNames": ["argocd/values/infrastructure/**"],
      "groupName": "infrastructure"
    },
    {
      "matchFileNames": ["argocd/manifests/**"],
      "groupName": "manifests"
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": ["/argocd/(applications|infrastructure)/.+\\.ya?ml$/"],
      "datasourceTemplate": "helm",
      "matchStrings": [
        "- name:\\s+[\\w-]+\\s+chart:\\s+(?<depName>[\\w-]+)\\s+repoURL:\\s+(?<registryUrl>https?://\\S+)[\\s\\S]*?targetRevision:\\s+[\"']?(?<currentValue>[\\w.-]+)[\"']?",
        "- name:\\s+(?<depName>[\\w-]+)\\s+repoURL:\\s+(?<registryUrl>https?://\\S+)[\\s\\S]*?targetRevision:\\s+[\"']?(?<currentValue>[\\w.-]+)[\"']?",
        "repoURL:\\s+(?<registryUrl>https?://\\S+)\\s+chart:\\s+(?<depName>[\\w-]+)\\s+targetRevision:\\s+[\"']?(?<currentValue>[\\w.-]+)[\"']?"
      ]
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/argocd/apps/.+/config\\.ya?ml$/"],
      "datasourceTemplate": "helm",
      "matchStrings": [
        "chart:\\s+(?<depName>[\\w-]+)\\s+repoURL:\\s+(?<registryUrl>\\S+)[\\s\\S]*?targetRevision:\\s+[\"']?(?<currentValue>[\\w.-]+)[\"']?"
      ]
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/argocd/values/.+\\.ya?ml$/",
        "/argocd/manifests/.+\\.ya?ml$/",
        "/argocd/apps/.+\\.ya?ml$/"
      ],
      "datasourceTemplate": "docker",
      "matchStrings": [
        "#\\s*renovate:\\s*image=(?<depName>[^\\s]+)\\s*\\n\\s*image:\\s+[\"']?(?<currentValue>[^\"'\\s]+)[\"']?",
        "#\\s*renovate:\\s*datasource=(?<datasourceTemplate>\\S+)\\s+depName=(?<depName>\\S+)\\s*\\n.*?[\"']?(?<currentValue>v?[0-9][^\"'\\s]*)[\"']?"
      ]
    }
  ]
}
