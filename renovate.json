{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":dependencyDashboard",
    ":pinDependencies",
    "helpers:pinGitHubActionDigests"
  ],
  "timezone": "UTC",
  "schedule": ["before 6am on monday"],
  "prConcurrentLimit": 10,
  "prHourlyLimit": 4,
  "labels": ["dependencies"],
  "commitMessagePrefix": "chore(deps):",
  "rebaseWhen": "conflicted",
  "packageRules": [
    {
      "matchUpdateTypes": ["major"],
      "addLabels": ["major"],
      "dependencyDashboardApproval": true
    },
    {
      "matchDatasources": ["docker"],
      "matchUpdateTypes": ["digest"],
      "enabled": false
    },
    {
      "matchUpdateTypes": ["patch", "pin"],
      "automerge": true,
      "addLabels": ["automerge"],
      "description": "Auto-merge patch and pin updates once PR is mergeable"
    },
    {
      "matchManagers": ["github-actions"],
      "matchUpdateTypes": ["minor"],
      "automerge": true,
      "addLabels": ["automerge"],
      "description": "Auto-merge minor GitHub Actions bumps (low blast radius)"
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/argocd/.+\\.ya?ml$/"
      ],
      "matchStrings": [
        "repoURL:\\s+(?<registryUrl>https?://[^\\s]+)\\s+chart:\\s+(?<depName>[^\\s]+)\\s+targetRevision:\\s+[\"']?(?<currentValue>[0-9][^\\s\"']*)[\"']?"
      ],
      "datasourceTemplate": "helm"
    }
  ]
}
